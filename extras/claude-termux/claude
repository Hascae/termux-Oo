#!/data/data/com.termux/files/usr/bin/bash
# =============================================================================
#  claude — launcher that runs Claude Code inside the glibc (Debian) sandbox.
#
#  The current Termux working directory is bound into the sandbox at the same
#  path and used as the working directory, so Claude operates on your real
#  files. On first use it triggers the one-time claude-setup.
# =============================================================================
set -euo pipefail

DISTRO="${CLAUDE_TERMUX_DISTRO:-debian}"
# proot-distro keeps installed rootfses under .../proot-distro/containers/<distro>.
PDROOT="${PREFIX:-/data/data/com.termux/files/usr}/var/lib/proot-distro/containers/$DISTRO"

# Consider the sandbox ready if that container dir exists (fast path); fall back to actually
# entering the sandbox (`login -- true`) as insurance. Only if both fail do we run setup.
sandbox_ready() {
    [ -d "$PDROOT" ] && return 0
    proot-distro login "$DISTRO" -- true >/dev/null 2>&1
}

if ! command -v proot-distro >/dev/null 2>&1 || ! sandbox_ready; then
    echo "Setting up the Claude sandbox (one-time, needs network)..." >&2
    claude-setup
fi

CWD="$(pwd)"

# --bind shares the current dir into the sandbox at the same path; the inner
# bash cds there before launching claude. $0 inside `bash -lc` is the first
# positional arg (CWD), and "$@" is the remaining claude arguments.
exec proot-distro login "$DISTRO" --bind "$CWD:$CWD" -- \
    bash -lc 'cd "$0" && exec claude "$@"' "$CWD" "$@"
