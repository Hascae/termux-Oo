#!/data/data/com.termux/files/usr/bin/bash
# =============================================================================
#  claude-setup — one-time setup for running Claude Code on Termux.
#
#  Claude Code v2.1.113+ ships as a native glibc Linux binary with no JS
#  fallback, so it cannot run on Termux's bionic libc directly. We run it
#  inside a proot Debian sandbox (which provides glibc). Everything heavy
#  installs here, into $HOME — nothing is baked into the app, and the Termux
#  bootstrap / exec / signing are never touched.
#
#  Re-runnable: safe to run again to repair or update the sandbox.
# =============================================================================
set -euo pipefail

DISTRO="${CLAUDE_TERMUX_DISTRO:-debian}"

say() { printf '\033[1;36m>> %s\033[0m\n' "$*"; }

say "Claude Code (Termux) setup — distro: $DISTRO"

say "[1/4] Installing proot-distro ..."
pkg install -y proot-distro

say "[2/4] Installing $DISTRO rootfs (if needed) ..."
# proot-distro keeps installed rootfses under .../proot-distro/containers/<distro>; the
# `login -- true` probe is the fallback insurance.
PDROOT="${PREFIX:-/data/data/com.termux/files/usr}/var/lib/proot-distro/containers/$DISTRO"
if [ -d "$PDROOT" ] || proot-distro login "$DISTRO" -- true >/dev/null 2>&1; then
    echo "   already installed"
else
    # Tolerate a spurious re-install: if the container already exists, don't abort (set -e).
    proot-distro install "$DISTRO" || echo "   (install reported an error; assuming already present, continuing)"
fi

say "[3/4] Installing Node.js + Claude Code inside $DISTRO ..."
proot-distro login "$DISTRO" -- bash -lc '
    set -e
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends curl ca-certificates xz-utils
    if ! command -v node >/dev/null 2>&1; then
        # Claude Code needs a recent Node; use the NodeSource LTS line.
        curl -fsSL https://deb.nodesource.com/setup_lts.x | bash -
        apt-get install -y nodejs
    fi
    npm install -g @anthropic-ai/claude-code
    claude --version || true
'

say "[4/4] Done."
echo "   Run:  claude          (from any directory — your current folder is shared in)"
echo "   First launch will ask you to log in (opens a URL to paste in your phone browser)."
